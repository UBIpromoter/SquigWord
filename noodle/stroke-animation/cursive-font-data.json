  "hersheyFont": {
    "name": "Hershey Script Simplex",
    "type": "Hershey vector format",
    "format": {
      "description": "Each character pair is a coordinate: subtract ASCII 'R' (82) from each char to get x,y. 'R' marks pen-up (move without drawing).",
      "leftMargin": "First char defines left margin",
      "rightMargin": "Second char defines right margin",
      "coordinates": "Remaining pairs are x,y coords where R=0. Space ' R' means pen up."
    },
    "decodeFunction": "function decodeHershey(data) { const coords = []; let penDown = true; for(let i=2; i<data.length; i+=2) { if(data[i]==' ' && data[i+1]==='R') { penDown=false; i++; continue; } const x = data.charCodeAt(i) - 82; const y = data.charCodeAt(i+1) - 82; coords.push({x, y, penDown}); penDown=true; } return coords; }",
